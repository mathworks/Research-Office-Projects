    </link>
    <joint name="front_left_hip_y" type="revolute">
        <origin xyz="0.0 0.110945 0.0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <parent link="front_left_hip" /><child link="front_left_upper_leg" />
        <limit effort="1000" velocity="1000" lower="-0.898845" upper="2.295108" />
